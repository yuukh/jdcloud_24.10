+/*
+ * CPU generated traffic is marked at the bridge LOCAL_OUT hook and is only
+ * handed back to PPE after it reaches the Wi-Fi ndo_start_xmit callback.
+ * This keeps qdisc/GSO validation and WED flow control in front of the direct
+ * PPE -> WDMA -> WED path.  The bit is private to this short section of the
+ * transmit path and is cleared before either hardware or software transmit.
+ */
+#define HNAT_CPU_WIFI_PENDING	0x80000000U
+#define HNAT_CPU_WIFI_CB_MAGIC	0x43505746U
+#define HNAT_CPU_WIFI_CB(skb)	(*(u32 *)&(skb)->cb[44])
+
+static inline bool hnat_cpu_wifi_is_pending(struct sk_buff *skb)
+{
+	return (skb->mark & HNAT_CPU_WIFI_PENDING) &&
+	       READ_ONCE(HNAT_CPU_WIFI_CB(skb)) == HNAT_CPU_WIFI_CB_MAGIC;
+}
+
+static inline void hnat_cpu_wifi_set_pending(struct sk_buff *skb)
+{
+	skb->mark |= HNAT_CPU_WIFI_PENDING;
+	HNAT_CPU_WIFI_CB(skb) = HNAT_CPU_WIFI_CB_MAGIC;
+}
+
+static inline void hnat_cpu_wifi_clear_pending(struct sk_buff *skb)
+{
+	skb->mark &= ~HNAT_CPU_WIFI_PENDING;
+	HNAT_CPU_WIFI_CB(skb) = 0;
+}
+
+enum hnat_cpu_wifi_xmit_result {
+	HNAT_CPU_WIFI_XMIT_FALLBACK,
+	HNAT_CPU_WIFI_XMIT_CONSUMED,
+	HNAT_CPU_WIFI_XMIT_BUSY,
+};
