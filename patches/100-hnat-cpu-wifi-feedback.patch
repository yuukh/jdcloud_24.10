+static bool
+warp_cpu_wifi_credit_available(struct warp_entry *warp, u32 needed,
+			       bool reserve, bool wake_level)
+{
+	struct warp_cpu_wifi_fc *fc = &warp->cpu_wifi_fc;
+	u32 status, alloc_mib, ring_cnt, ring_cidx, ring_didx;
+	u32 delta, used, effective, window, ring_window, ring_queued;
+	unsigned long flags;
+	u16 free;
+	bool available;
+
+	if (!warp->wed.base_addr)
+		return false;
+
+	warp_io_read32(&warp->wed, WED_TX_BM_STS, &status);
+	warp_io_read32(&warp->wed,
+		       WED_TX_BM_TO_WDMA_RX_DRV_SKBID_MIB, &alloc_mib);
+	warp_io_read32(&warp->wed, WED_WPDMA_TX1_CTRL1, &ring_cnt);
+	warp_io_read32(&warp->wed, WED_WPDMA_TX1_CTRL2, &ring_cidx);
+	warp_io_read32(&warp->wed, WED_WPDMA_TX1_CTRL3, &ring_didx);
+	free = status & 0xffff;
+	ring_cnt &= 0xfff;
+	if (unlikely(ring_cnt < 2))
+		return false;
+	ring_cidx &= 0xfff;
+	ring_didx &= 0xfff;
+	ring_queued = ring_cidx >= ring_didx ?
+		      ring_cidx - ring_didx :
+		      ring_cidx - ring_didx + ring_cnt;
+	window = clamp_t(u32, cpu_wifi_credit_window,
+			 max_t(u32, 32, cpu_wifi_gso_max_segs * 2), 4096);
+	ring_window = clamp_t(u32, cpu_wifi_ring_window,
+			      min_t(u32, max_t(u32, 32,
+					       cpu_wifi_gso_max_segs * 2),
+				    ring_cnt - 1),
+			      ring_cnt - 1);
+
+	spin_lock_irqsave(&fc->lock, flags);
+
+	if (!fc->baseline_free || free > fc->baseline_free)
+		fc->baseline_free = free;
+	fc->last_free = free;
+	fc->last_ring_queued = ring_queued;
+
+	if (!fc->mib_valid) {
+		fc->last_alloc_mib = alloc_mib;
+		fc->mib_valid = true;
+	} else {
+		delta = alloc_mib - fc->last_alloc_mib;
+		fc->last_alloc_mib = alloc_mib;
+		if (delta >= fc->reserved)
+			fc->reserved = 0;
+		else
+			fc->reserved -= delta;
+	}
+
+	used = fc->baseline_free > free ?
+	       fc->baseline_free - free : 0;
+	effective = used + fc->reserved;
+
+	if (wake_level)
+		available = effective <= window / 2 &&
+			    ring_queued <= ring_window / 2;
+	else
+		available = effective + needed <= window &&
+			    ring_queued + needed <= ring_window;
+
+	if (available && reserve)
+		fc->reserved += needed;
+
+	spin_unlock_irqrestore(&fc->lock, flags);
+	return available;
+}
+
+static enum hrtimer_restart
+warp_cpu_wifi_wake_timer(struct hrtimer *timer)
+{
+	struct warp_cpu_wifi_fc *fc =
+		container_of(timer, struct warp_cpu_wifi_fc, wake_timer);
+	struct warp_entry *warp =
+		container_of(fc, struct warp_entry, cpu_wifi_fc);
+	struct net_device *blocked[WARP_CPU_WIFI_MAX_BLOCKED_DEVS] = {};
+	unsigned long flags;
+	bool have_running = false;
+	int i;
+
+	spin_lock_irqsave(&fc->lock, flags);
+	for (i = 0; i < ARRAY_SIZE(fc->blocked); i++) {
+		if (!fc->blocked[i])
+			continue;
+		if (netif_running(fc->blocked[i])) {
+			have_running = true;
+			continue;
+		}
+		blocked[i] = fc->blocked[i];
+		fc->blocked[i] = NULL;
+	}
+	spin_unlock_irqrestore(&fc->lock, flags);
+
+	for (i = 0; i < ARRAY_SIZE(blocked); i++) {
+		if (blocked[i]) {
+			dev_put(blocked[i]);
+			blocked[i] = NULL;
+		}
+	}
+
+	if (!have_running)
+		return HRTIMER_NORESTART;
+
+	if (!warp_cpu_wifi_credit_available(warp, 0, false, true)) {
+		hrtimer_forward_now(timer,
+			ns_to_ktime(clamp_t(u32, cpu_wifi_credit_poll_us,
+					   50, 2000) * NSEC_PER_USEC));
+		return HRTIMER_RESTART;
+	}
+
+	spin_lock_irqsave(&fc->lock, flags);
+	for (i = 0; i < ARRAY_SIZE(fc->blocked); i++) {
+		blocked[i] = fc->blocked[i];
+		fc->blocked[i] = NULL;
+	}
+	spin_unlock_irqrestore(&fc->lock, flags);
+
+	for (i = 0; i < ARRAY_SIZE(blocked); i++) {
+		if (!blocked[i])
+			continue;
+		if (netif_running(blocked[i]))
+			netif_wake_queue(blocked[i]);
+		dev_put(blocked[i]);
+	}
+
+	spin_lock_irqsave(&fc->lock, flags);
+	fc->wakes++;
+	spin_unlock_irqrestore(&fc->lock, flags);
+
+	return HRTIMER_NORESTART;
+}
+
+static bool
+warp_cpu_wifi_block_netdev(struct warp_entry *warp,
+			   struct net_device *netdev)
+{
+	struct warp_cpu_wifi_fc *fc = &warp->cpu_wifi_fc;
+	unsigned long flags;
+	int i, free_slot = -1;
+	bool found = false;
+
+	spin_lock_irqsave(&fc->lock, flags);
+	for (i = 0; i < ARRAY_SIZE(fc->blocked); i++) {
+		if (fc->blocked[i] == netdev) {
+			found = true;
+			break;
+		}
+		if (!fc->blocked[i] && free_slot < 0)
+			free_slot = i;
+	}
+
+	if (!found && free_slot >= 0) {
+		dev_hold(netdev);
+		fc->blocked[free_slot] = netdev;
+		found = true;
+	}
+	if (found)
+		fc->busy++;
+	else
+		fc->fallback++;
+	spin_unlock_irqrestore(&fc->lock, flags);
+
+	if (!found)
+		return false;
+
+	netif_stop_queue(netdev);
+	hrtimer_start(&fc->wake_timer,
+		      ns_to_ktime(clamp_t(u32, cpu_wifi_credit_poll_us,
+					 50, 2000) * NSEC_PER_USEC),
+		      HRTIMER_MODE_REL_PINNED);
+	return true;
+}
+
+static void
+warp_cpu_wifi_release_blocked(struct warp_entry *warp)
+{
+	struct warp_cpu_wifi_fc *fc = &warp->cpu_wifi_fc;
+	struct net_device *blocked[WARP_CPU_WIFI_MAX_BLOCKED_DEVS] = {};
+	unsigned long flags;
+	int i;
+
+	hrtimer_cancel(&fc->wake_timer);
+
+	spin_lock_irqsave(&fc->lock, flags);
+	for (i = 0; i < ARRAY_SIZE(fc->blocked); i++) {
+		blocked[i] = fc->blocked[i];
+		fc->blocked[i] = NULL;
+	}
+	spin_unlock_irqrestore(&fc->lock, flags);
+
+	for (i = 0; i < ARRAY_SIZE(blocked); i++)
+		if (blocked[i])
+			dev_put(blocked[i]);
+}
+
+void
+warp_cpu_wifi_configure_netdev(struct net_device *netdev)
+{
+	u32 max_size = clamp_t(u32, cpu_wifi_gso_max_size, 4096, 65536);
+	u32 max_segs = clamp_t(u32, cpu_wifi_gso_max_segs, 1, 64);
+
+	netif_set_gso_max_size(netdev, min_t(u32, netdev->gso_max_size,
+					     max_size));
+	netif_set_gso_ipv4_max_size(netdev,
+				   min_t(u32, netdev->gso_ipv4_max_size,
+					 max_size));
+	netif_set_gso_max_segs(netdev, min_t(u32, netdev->gso_max_segs,
+					     max_segs));
+}
+EXPORT_SYMBOL(warp_cpu_wifi_configure_netdev);
+
+int
+warp_cpu_wifi_xmit(void *priv_data, struct sk_buff *skb,
+		   struct net_device *netdev)
+{
+	struct warp_entry *warp;
+	struct warp_cpu_wifi_fc *fc;
+	unsigned long flags;
+	u32 needed;
+	int ret;
+
+	if (!hnat_cpu_wifi_is_pending(skb))
+		return HNAT_CPU_WIFI_XMIT_FALLBACK;
+
+	warp = warp_entry_get_by_privdata(priv_data);
+	if (!warp || !warp->cfg.hw_tx_en || !ra_sw_nat_hook_cpu_to_wifi) {
+		hnat_cpu_wifi_clear_pending(skb);
+		return HNAT_CPU_WIFI_XMIT_FALLBACK;
+	}
+
+	fc = &warp->cpu_wifi_fc;
+	needed = skb_is_gso(skb) ? skb_shinfo(skb)->gso_segs : 1;
+	if (!needed)
+		needed = 1;
+
+	/*
+	 * This should already have been enforced by netdev feature validation.
+	 * Keep a defensive fallback so an invalid super-frame cannot bypass the
+	 * bounded WED admission window.
+	 */
+	if (unlikely(needed > clamp_t(u32, cpu_wifi_gso_max_segs, 1, 64))) {
+		hnat_cpu_wifi_clear_pending(skb);
+		spin_lock_irqsave(&fc->lock, flags);
+		fc->fallback++;
+		spin_unlock_irqrestore(&fc->lock, flags);
+		return HNAT_CPU_WIFI_XMIT_FALLBACK;
+	}
+
+	if (!warp_cpu_wifi_credit_available(warp, needed, true, false)) {
+		if (warp_cpu_wifi_block_netdev(warp, netdev))
+			return HNAT_CPU_WIFI_XMIT_BUSY;
+
+		hnat_cpu_wifi_clear_pending(skb);
+		return HNAT_CPU_WIFI_XMIT_FALLBACK;
+	}
+
+	ret = ra_sw_nat_hook_cpu_to_wifi(skb);
+	spin_lock_irqsave(&fc->lock, flags);
+	if (ret == HNAT_CPU_WIFI_XMIT_CONSUMED) {
+		fc->admitted += needed;
+	} else {
+		if (fc->reserved >= needed)
+			fc->reserved -= needed;
+		else
+			fc->reserved = 0;
+		fc->fallback++;
+	}
+	spin_unlock_irqrestore(&fc->lock, flags);
+
+	return ret;
+}
+EXPORT_SYMBOL(warp_cpu_wifi_xmit);
