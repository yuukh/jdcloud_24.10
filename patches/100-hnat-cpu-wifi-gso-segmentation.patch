+static void hnat_cpu_to_ge_xmit(struct sk_buff *skb)
+{
+	u16 vlan_id = skb_vlan_tag_get_id(skb);
+
+	if (unlikely(vlan_id)) {
+		skb = vlan_insert_tag(skb, skb->vlan_proto, skb->vlan_tci);
+		if (!skb)
+			return;
+	}
+
+	if (unlikely(skb_headroom(skb) < FOE_INFO_LEN) &&
+	    unlikely(skb_cow(skb, FOE_INFO_LEN))) {
+		dev_kfree_skb_any(skb);
+		return;
+	}
+
+	/* skb_gso_segment() only preserves the first 32 bytes of skb->cb and
+	 * allocates fresh headroom for every segment. Restore both vendor HNAT
+	 * metadata areas after segmentation, immediately before queueing.
+	 */
+	memset(skb_hnat_info(skb), 0, FOE_INFO_LEN);
+	skb_hnat_alg(skb) = 0;
+	skb_hnat_magic_tag(skb) = HNAT_MAGIC_TAG;
+	skb_hnat_filled(skb) = 0;
+	set_to_ppe(skb);
+
+	/* Set where the reinjected packet came from. */
+	__vlan_hwaccel_put_tag(skb, htons(ETH_P_8021Q),
+			       VLAN_CFI_MASK | (1234 & VLAN_VID_MASK));
+	skb->dev = hnat_priv->g_ppdev;
+	dev_queue_xmit(skb);
+}
