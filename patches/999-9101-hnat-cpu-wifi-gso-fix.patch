From: MedyMa <aneylovemzy@gmail.com>
Date: Tue, 22 Jul 2026 00:00:00 +0800
Subject: [PATCH] mtk_hnat: fix CPU-to-WiFi TCP retransmissions caused by GSO

The MTK HNAT do_hnat_cpu_to_ge() pushes CPU-generated GSO frames directly
to WiFi via WED/PPE, but the WiFi MAC cannot handle oversized frames,
causing TCP retransmissions.

Fix by restoring the Ethernet header before skb_gso_segment(), then
recursively enqueueing each wire-sized segment through the same function.
Unlike the 6.6.94 source branch, the default source uses Linux 6.6.133 and
supports TCP GSO frag lists. Allow those through segmentation as well.
Segmentation allocates fresh skb heads and uses the tail of skb->cb, so
reinitialize both vendor HNAT metadata areas for every segment.

Signed-off-by: MedyMa <aneylovemzy@gmail.com>
---
 drivers/net/ethernet/mediatek/mtk_hnat/hnat_nf_hook.c | 28 +++++++++++++++++++-
 1 file changed, 27 insertions(+), 1 deletion(-)

--- a/drivers/net/ethernet/mediatek/mtk_hnat/hnat_nf_hook.c
+++ b/drivers/net/ethernet/mediatek/mtk_hnat/hnat_nf_hook.c
@@ -24,6 +24,7 @@
 #include <net/ip.h>
 #include <net/tcp.h>
 #include <net/udp.h>
+#include <net/gso.h>
 #include <net/netfilter/nf_conntrack.h>
 #include <net/netfilter/nf_conntrack_acct.h>
 #include "nf_hnat_mtk.h"
@@ -1003,7 +1004,10 @@
 
 static unsigned int do_hnat_cpu_to_ge(struct sk_buff *skb)
 {
-	if (unlikely(skb_shinfo(skb)->frag_list))
+	struct sk_buff *segs, *nskb;
+	netdev_features_t features;
+
+	if (unlikely(skb_shinfo(skb)->frag_list && !skb_is_gso(skb)))
                 return -1;
 	if (unlikely(skb->mark == HNAT_EXCEPTION_TAG))
 				return -1;
@@ -1011,6 +1015,7 @@
                 if(unlikely(skb_cow(skb, FOE_INFO_LEN + ETH_HLEN)))
                 return -1;
     }
+	memset(skb_hnat_info(skb), 0, FOE_INFO_LEN);
 	skb_hnat_alg(skb) = 0;
 	skb_hnat_magic_tag(skb) = HNAT_MAGIC_TAG;
 	skb_hnat_filled(skb) = 0;
@@ -1023,6 +1028,27 @@
                 u16 vlan_id = 0;
                 skb_set_network_header(skb, 0);
                 skb_push(skb, ETH_HLEN);
+		if (skb_is_gso(skb)) {
+			skb_reset_mac_header(skb);
+			features = hnat_priv->g_ppdev->features & ~NETIF_F_GSO_MASK;
+			segs = skb_gso_segment(skb, features);
+			if (IS_ERR(segs)) {
+				dev_kfree_skb_any(skb);
+				return 0;
+			}
+
+			if (segs) {
+				consume_skb(skb);
+				skb_list_walk_safe(segs, skb, nskb) {
+					skb_mark_not_on_list(skb);
+					skb_pull(skb, ETH_HLEN);
+					if (do_hnat_cpu_to_ge(skb))
+						kfree_skb(skb);
+				}
+				return 0;
+			}
+		}
+
 		set_to_ppe(skb);
                 vlan_id = skb_vlan_tag_get_id(skb);
                 if (unlikely(vlan_id)) {
